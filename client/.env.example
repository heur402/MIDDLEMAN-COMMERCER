# API base URL — only needed if NOT using the Vite proxy (i.e. deploying separately)
# When running via `npm run dev` with the proxy configured in vite.config.js, leave this blank.
VITE_API_URL=http://localhost:5000

# Socket.IO server URL — leave blank to default to window.location.origin
VITE_SOCKET_URL=http://localhost:5000
