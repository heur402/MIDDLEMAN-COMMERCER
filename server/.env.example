# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/middleman_db

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cloudinary (leave blank to use local /uploads fallback) ──────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
